# ── Supabase ──────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://<project>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>        # server only — never expose to browser

# ── Credential encryption (AES-256-GCM) ──────────────────────
CREDENTIALS_ENCRYPTION_KEY=<64-hex-chars>           # generate: openssl rand -hex 32

# ── Anthropic ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Upstash Redis ─────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://<db>.upstash.io
UPSTASH_REDIS_REST_TOKEN=<token>
UPSTASH_REDIS_URL=rediss://default:<token>@<host>:<port>   # ioredis binary protocol for BullMQ

# ── Cron security ─────────────────────────────────────────────
CRON_SECRET=<random-string>                         # generate: openssl rand -hex 32

# ── Worker (Railway only) ─────────────────────────────────────
SUPABASE_URL=https://<project>.supabase.co          # same as NEXT_PUBLIC_SUPABASE_URL
WORKER_CONCURRENCY=3
WEB_URL=https://<your-vercel-domain>.vercel.app
